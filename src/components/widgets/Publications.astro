---
// Publications.astro - Lista de publicaciones científicas
// Para agregar una nueva publicación, solo añade un objeto al array 'publications'

interface Publication {
  title: string;
  journal: string;
  year: number;
  authors: string;
  doi?: string;
  url?: string;
  type: 'journal' | 'conference' | 'preprint';
}

const publications: Publication[] = [
  {
    title: 'Wearable Biosensor Technology in Education: A Systematic Review',
    journal: 'Sensors',
    year: 2024,
    authors: 'Hernández-Mustieles MA, Lima-Carmona YE, Pacheco-Ramírez MA, et al.',
    doi: '10.3390/s24082437',
    url: 'https://www.mdpi.com/1424-8220/24/8/2437',
    type: 'journal',
  },
  {
    title: "Neural Dynamics of Creative Movements During the Rehearsal and Performance of 'LiveWire'",
    journal: 'Scientific Data (Nature)',
    year: 2024,
    authors:
      'Pacheco-Ramírez MA, Ramírez-Moreno MA, Kukkar K, Rao N, Huber D, Brandt AK, Noble A, Noble D, Ealey B, Contreras-Vidal JL',
    doi: '10.1038/s41597-024-04010-8',
    url: 'https://www.nature.com/articles/s41597-024-04010-8',
    type: 'journal',
  },
  {
    title: 'At-Home Stroke Neurorehabilitation: Early Findings with the NeuroExo BCI System',
    journal: 'Sensors',
    year: 2025,
    authors:
      'González-España JJ, Sánchez-Rodríguez L, Pacheco-Ramírez MA, Feng J, Nedley K, Chang S-H, Francisco GE, Contreras-Vidal JL',
    doi: '10.3390/s25051322',
    url: 'https://www.mdpi.com/1424-8220/25/5/1322',
    type: 'journal',
  },
  {
    title: 'An Artistic BCI–GenAI System Enabling Real-Time Co-creation in Balinese Performance',
    journal: 'International Workshop on Creative AI for Live Interactive Performances',
    year: 2026,
    authors: 'Aguilar-Herrera AJ, Hernández-Aguado CO, Monarres-Sokolovskaya JA, et al.',
    url: 'https://scholar.google.com/citations?user=2HG3KP4AAAAJ&hl=en',
    type: 'conference',
  },
];

const { title = 'Publications', id } = Astro.props;
---

<section class="py-16 px-4" {...id ? { id } : {}}>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">{title}</h2>

    <div class="space-y-6">
      {
        publications.map((pub) => (
          <article class="bg-white dark:bg-slate-800 rounded-lg p-6 shadow-sm border border-gray-100 dark:border-slate-700 hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0">
                <span
                  class={`inline-flex items-center justify-center w-12 h-12 rounded-lg text-white font-bold text-sm
                ${pub.type === 'journal' ? 'bg-purple-600' : pub.type === 'conference' ? 'bg-blue-600' : 'bg-gray-600'}`}
                >
                  {pub.year.toString().slice(-2)}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                  {pub.url ? (
                    <a
                      href={pub.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors"
                    >
                      {pub.title}
                    </a>
                  ) : (
                    pub.title
                  )}
                </h3>
                <p class="text-purple-600 dark:text-purple-400 font-medium mb-1">{pub.journal}</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">{pub.authors}</p>
                {pub.doi && (
                  <p class="text-xs text-gray-500 dark:text-gray-500">
                    DOI:{' '}
                    <a
                      href={`https://doi.org/${pub.doi}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hover:text-purple-600 dark:hover:text-purple-400"
                    >
                      {pub.doi}
                    </a>
                  </p>
                )}
              </div>
              <div class="flex-shrink-0">
                {pub.url && (
                  <a
                    href={pub.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 hover:bg-purple-200 dark:hover:bg-purple-900/50 transition-colors"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-5 h-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    {publications.length === 0 && <p class="text-center text-gray-500 dark:text-gray-400 py-8">No publications yet.</p>}
  </div>
</section>
