---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
const metadata = {
  title: 'Maxine Annel Pacheco-Ramírez',
  ignoreTitleTemplate: true,
};
---
<Layout metadata={metadata}>
  <Hero2
    tagline="ABOUT ME"
    image={{ src: '~/assets/images/max_polo.JPG', alt: 'Maxine Image' }}
    actions={[
      {
        variant: 'primary',
        text: 'Resume',
        href: 'https://uh.edu',
        icon: 'tabler:list-check',
      },
      {
        text: 'Github',
        href: 'https://github.com/MaxineAnnelPachecoRamirez',
        icon: 'tabler:brand-github',
      },
      {
        text: 'LinkedIn',
        href: 'https://www.linkedin.com/in/annelpacheco/',
        icon: 'tabler:brand-linkedin',
      },
      {
        text: 'My projects',
        href: '#Projs',
        icon: 'tabler:tool',
      },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white highlight">Who am I?</span><br />
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">I'm Maxine Annel Pacheco-Ramírez</span> — a scientist who believes the brain is the most fascinating thing in the universe. 
        <br /><br />
        As a PhD researcher at the IUCRC BRAIN Center, University of Houston, I use cutting-edge EEG technology to decode how the brain responds to music, dance, art, and human connection. My work has taken me from the stages of Geneva's AI for Good Summit to the rice paddies of Bali, Indonesia, from MD Anderson Cancer Center to Rice University — always chasing the same question: <em>what happens in our brains when we create, connect, and heal?</em>
        <br /><br />
        I graduated top of my class in Biomedical Engineering at Tecnológico de Monterrey, and today I lead projects blending neuroscience with art performances, stroke rehabilitation, Alzheimer's research, and emotion recognition.
      </span>
    </Fragment>
  </Hero2>
  <BlogLatestPosts title="Projects" id="Projs" />
  <Steps
    id="edu"
    title="Education"
    items={[
      {
        title: `Ph.D. in Electrical and Computer Engineering <br /> <span class="font-normal">University of Houston</span> <br /> <span class="text-sm font-normal">2023 - 2028 (expected)</span>`,
        icon: 'tabler:school',
      },
      {
        title: `B.Eng. in Biomedical Engineering <br /> <span class="font-normal">Tecnológico de Monterrey</span> <br /> <span class="text-sm font-normal">2019 - 2023 · Highest GPA of class 🏆</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />
  <Features2
    title="Contact"
    items={[
      {
        title: 'Phone',
        description: '(832) 455-1363',
        icon: 'tabler:headset',
      },
      {
        title: 'Email',
        description: 'mpachec4@cougarnet.uh.edu',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'University of Houston, Houston, Texas, USA',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
