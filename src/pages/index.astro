---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Publications from '~/components/widgets/Publications.astro';
const metadata = {
  title: 'Maxine Annel Pacheco-Ramírez',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="ABOUT ME"
    video="6UpOGJ7dyYU"
    actions={[
      {
        variant: 'primary',
        text: 'LinkedIn',
        href: 'https://www.linkedin.com/in/annelpacheco/',
        icon: 'tabler:brand-linkedin',
      },
      {
        text: 'Google Scholar',
        href: 'https://scholar.google.com/citations?user=2HG3KP4AAAAJ&hl=en',
        icon: 'tabler:school',
      },
      {
        text: 'My projects',
        href: '#Projs',
        icon: 'tabler:tool',
      },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white highlight">Who am I?</span><br />
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">I'm Maxine Annel Pacheco-Ramírez</span> — PhD researcher at the
        <span class="font-semibold">IUCRC BRAIN Center, University of Houston</span>, using EEG to decode how the brain
        responds to music, dance, art, and human connection.
        <br /><br />
        From Geneva's UN AI for Good Summit to Bali's rice paddies, from MD Anderson Cancer Center to Rice University — I
        chase one question: <em>what happens in our brains when we create, connect, and heal?</em>
        <br /><br />
        <span class="text-sm text-gray-500 dark:text-gray-400">
          NSF AccelNet Coordinator · BRAIN-AccelNet Student Network Treasurer · Noninvasive Brain-Machine Interface
          Systems Lab · B.Eng. Biomedical Engineering, Tecnológico de Monterrey (Highest GPA)
        </span>
      </span>
    </Fragment>
  </Hero2>

  <BlogLatestPosts title="Projects" id="Projs" />

  <Publications title="Publications" id="pubs" />
  <Steps
    id="edu"
    title="Education"
    items={[
      {
        title: `Ph.D. in Electrical and Computer Engineering <br /> <span class="font-normal">University of Houston</span> <br /> <span class="text-sm font-normal">2023 - 2028 (expected)</span>`,
        icon: 'tabler:school',
      },
      {
        title: `B.Eng. in Biomedical Engineering <br /> <span class="font-normal">Tecnológico de Monterrey</span> <br /> <span class="text-sm font-normal">2019 - 2023 · Highest GPA of class 🏆</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />
  <Features2
    title="Contact"
    items={[
      {
        title: 'Phone',
        description: '(832) 455-1363',
        icon: 'tabler:headset',
      },
      {
        title: 'Email',
        description: 'mpachec4@cougarnet.uh.edu',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'University of Houston, Houston, Texas, USA',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
